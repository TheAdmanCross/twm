---
import { existsSync } from "node:fs";
import { withBasePath } from "../utils/links";

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
const pathname = Astro.url.pathname;

const navItems = [
  { href: "/", label: "Home" },
  { href: "/pricing-plans/plans-pricing", label: "VIP Plans" },
  { href: "/contact", label: "Contact" }
];

const exactLogoPath = "/assets/images/matt-logo.png";
const hasExactLogo = existsSync(new URL("../../public/assets/images/matt-logo.png", import.meta.url));
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600;700&family=Manrope:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <style is:global>
      :root {
        --bg: #070506;
        --bg-soft: #13090a;
        --bg-elevated: #1b0b0e;
        --panel: rgba(26, 11, 14, 0.68);
        --panel-strong: rgba(36, 13, 16, 0.88);
        --line: rgba(255, 212, 169, 0.18);
        --line-soft: rgba(255, 255, 255, 0.08);
        --text: #f8f2ed;
        --muted: rgba(239, 225, 215, 0.74);
        --accent: #b31919;
        --accent-soft: #ff5447;
        --gold: #d4af37;
        --gold-soft: #f2d77a;
        --logo-blue-a: #8bb7ea;
        --logo-blue-b: #507eaf;
        --glow-red: rgba(179, 25, 25, 0.32);
        --glow-gold: rgba(212, 175, 55, 0.22);
        --shadow: 0 40px 120px rgba(0, 0, 0, 0.48);
        --radius: 30px;
        --container: min(1200px, calc(100vw - 2rem));
      }

      * {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        font-family: "Manrope", sans-serif;
        color: var(--text);
        background:
          radial-gradient(circle at 18% 10%, rgba(179, 25, 25, 0.28), transparent 22%),
          radial-gradient(circle at 80% 16%, rgba(212, 175, 55, 0.16), transparent 16%),
          radial-gradient(circle at 50% 0%, rgba(255, 255, 255, 0.05), transparent 28%),
          linear-gradient(180deg, #0b0506 0%, #070506 42%, #050304 100%);
        min-height: 100vh;
      }

      body::before {
        content: "";
        position: fixed;
        inset: 0;
        background-image:
          linear-gradient(rgba(212, 175, 55, 0.045) 1px, transparent 1px),
          linear-gradient(90deg, rgba(212, 175, 55, 0.04) 1px, transparent 1px);
        background-size: 96px 96px;
        mask-image: linear-gradient(180deg, rgba(0, 0, 0, 0.52), transparent 82%);
        pointer-events: none;
      }

      body::after {
        content: "";
        position: fixed;
        inset: 0;
        background:
          radial-gradient(circle at center, transparent 0%, transparent 55%, rgba(0, 0, 0, 0.4) 100%);
        pointer-events: none;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      img {
        max-width: 100%;
        display: block;
      }

      .container {
        width: var(--container);
        margin: 0 auto;
      }

      .section {
        padding: 6rem 0;
        position: relative;
      }

      .eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 0.7rem;
        padding: 0.58rem 1rem;
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.03);
        color: rgba(248, 242, 237, 0.8);
        font-size: 0.76rem;
        letter-spacing: 0.16em;
        text-transform: uppercase;
      }

      .eyebrow::before {
        content: "";
        width: 0.55rem;
        height: 0.55rem;
        border-radius: 999px;
        background: linear-gradient(135deg, var(--gold-soft), var(--gold));
        box-shadow: 0 0 24px var(--glow-gold);
      }

      h1,
      h2,
      h3 {
        margin: 0;
        line-height: 0.94;
      }

      h1,
      h2 {
        font-family: "Cormorant Garamond", serif;
        font-weight: 600;
      }

      h1 {
        font-size: clamp(4.25rem, 8vw, 7.4rem);
        letter-spacing: -0.045em;
      }

      h2 {
        font-size: clamp(2.8rem, 4.8vw, 4.7rem);
        letter-spacing: -0.04em;
      }

      h3 {
        font-size: 1.2rem;
      }

      p {
        margin: 0;
        color: var(--muted);
        line-height: 1.78;
      }

      .section-copy {
        display: grid;
        gap: 1rem;
        margin-bottom: 2rem;
        max-width: 49rem;
      }

      .glass-card {
        background:
          linear-gradient(180deg, rgba(255, 255, 255, 0.08), rgba(255, 255, 255, 0.015)),
          var(--panel);
        border: 1px solid var(--line);
        backdrop-filter: blur(24px);
        border-radius: var(--radius);
        box-shadow: var(--shadow);
      }

      .button-row {
        display: flex;
        flex-wrap: wrap;
        gap: 1rem;
      }

      .button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 3.6rem;
        padding: 0 1.5rem;
        border-radius: 999px;
        border: 1px solid transparent;
        font-weight: 700;
        letter-spacing: 0.02em;
        transition: transform 220ms ease, border-color 220ms ease, background 220ms ease, box-shadow 220ms ease;
        cursor: pointer;
      }

      .button:hover {
        transform: translateY(-2px);
      }

      .button-primary {
        background: linear-gradient(135deg, var(--gold-soft) 0%, var(--gold) 45%, #9b741b 100%);
        color: #170c03;
        box-shadow: 0 18px 36px rgba(155, 116, 27, 0.24);
      }

      .button-secondary {
        background: rgba(255, 255, 255, 0.04);
        border-color: rgba(255, 255, 255, 0.1);
      }

      .grid-3 {
        display: grid;
        gap: 1.25rem;
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }

      .site-shell {
        overflow: clip;
      }

      .site-header {
        position: sticky;
        top: 0;
        z-index: 20;
        backdrop-filter: blur(18px);
        background: rgba(6, 4, 5, 0.42);
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
      }

      .site-header-inner {
        width: var(--container);
        margin: 0 auto;
        min-height: 5rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1.25rem;
      }

      .brand-mark {
        display: inline-flex;
        align-items: center;
        gap: 0.95rem;
        min-width: 0;
      }

      .brand-mark-badge {
        width: 2.35rem;
        height: 2.35rem;
        border-radius: 999px;
        background:
          radial-gradient(circle at 35% 28%, rgba(255, 255, 255, 0.45), transparent 28%),
          linear-gradient(135deg, var(--logo-blue-a), var(--logo-blue-b));
        box-shadow:
          inset 0 1px 6px rgba(255, 255, 255, 0.28),
          0 0 30px rgba(139, 183, 234, 0.12);
      }

      .brand-logo-exact {
        height: 2.65rem;
        width: auto;
        object-fit: contain;
        flex: 0 0 auto;
      }

      .brand-mark-text strong {
        display: block;
        font-size: 1.8rem;
        font-weight: 800;
        letter-spacing: -0.04em;
        white-space: nowrap;
      }

      .site-nav {
        display: flex;
        align-items: center;
        gap: 0.7rem;
        margin-left: auto;
      }

      .site-nav a {
        padding: 0.75rem 1.15rem;
        border-radius: 999px;
        color: rgba(248, 242, 237, 0.76);
        transition: background 200ms ease, color 200ms ease;
        white-space: nowrap;
      }

      .site-nav a.is-active,
      .site-nav a:hover {
        background: rgba(255, 255, 255, 0.05);
        color: var(--text);
      }

      .kicker-list {
        display: flex;
        flex-wrap: wrap;
        gap: 0.85rem;
      }

      .kicker-pill {
        padding: 0.8rem 1rem;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.04);
        border: 1px solid rgba(255, 255, 255, 0.08);
        color: rgba(248, 242, 237, 0.88);
        font-size: 0.92rem;
      }

      .footer {
        padding: 2rem 0 3rem;
        color: rgba(248, 242, 237, 0.52);
        font-size: 0.9rem;
      }

      @media (max-width: 960px) {
        .grid-3 {
          grid-template-columns: 1fr;
        }

        .site-header-inner {
          min-height: 4.5rem;
          flex-wrap: wrap;
          justify-content: center;
          padding: 0.8rem 0;
        }

        .site-nav {
          width: 100%;
          justify-content: center;
          margin-left: 0;
          flex-wrap: wrap;
        }

        .section {
          padding: 4.5rem 0;
        }
      }

      @media (prefers-reduced-motion: reduce) {
        *,
        *::before,
        *::after {
          animation-duration: 0.01ms !important;
          animation-iteration-count: 1 !important;
          transition-duration: 0.01ms !important;
          scroll-behavior: auto !important;
        }
      }
    </style>
  </head>
  <body>
    <div class="site-shell">
      <header class="site-header">
        <div class="site-header-inner">
          <a class="brand-mark" href={withBasePath("/", base)}>
            {hasExactLogo ? (
              <>
                <img class="brand-logo-exact" src={exactLogoPath} alt="Trading With Matt logo" />
                <span class="brand-mark-text">
                  <strong>Trading With Matt</strong>
                </span>
              </>
            ) : (
              <>
                <span class="brand-mark-badge"></span>
                <span class="brand-mark-text">
                  <strong>Trading With Matt</strong>
                </span>
              </>
            )}
          </a>
          <nav class="site-nav" aria-label="Primary">
            {navItems.map((item) => (
              <a href={withBasePath(item.href, base)} class={pathname === item.href ? "is-active" : undefined}>{item.label}</a>
            ))}
          </nav>
          <a class="button button-secondary" href={withBasePath("/admin/", base)}>Login</a>
        </div>
      </header>
      <slot />
      <footer class="footer">
        <div class="container">Trading With Matt. Precision, access, and higher-standard market discipline.</div>
      </footer>
    </div>
  </body>
</html>
